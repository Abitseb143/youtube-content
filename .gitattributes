# Default — let git handle text normalization
* text=auto eol=lf

# Shell scripts MUST be LF for Linux containers
*.sh text eol=lf
*.bash text eol=lf

# Dockerfiles — LF
Dockerfile text eol=lf
*.Dockerfile text eol=lf

# Python — LF
*.py text eol=lf

# Web assets — let editor pick, but normalize to LF in repo
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
